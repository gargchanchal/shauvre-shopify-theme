{% comment %}
  Header Section - Shopify Theme
  Includes navigation, logo, search, cart drawer, and announcement slider
{% endcomment %}

<header class="sticky top-0 z-50 w-full bg-white/95 backdrop-blur-sm border-b border-gray-200">
  <!-- Announcement Bar Slider -->
  <div class="announcement-bar bg-brand-purple text-white">
    <div class="announcement-slider">
      <div class="announcement-track">
        <div class="announcement-slide active">
          <p class="text-sm font-medium">
            {% if section.settings.announcement_1 != blank %}
              {{ section.settings.announcement_1 }}
            {% else %}
              THE SUMMER COLLECTION HAS ARRIVED - SHOP NEW ARRIVALS NOW
            {% endif %}
          </p>
        </div>
        <div class="announcement-slide">
          <p class="text-sm font-medium">
            {% if section.settings.announcement_2 != blank %}
              {{ section.settings.announcement_2 }}
            {% else %}
              FREE SHIPPING ON ORDERS OVER $100 - LIMITED TIME OFFER
            {% endif %}
          </p>
        </div>
        <div class="announcement-slide">
          <p class="text-sm font-medium">
            {% if section.settings.announcement_3 != blank %}
              {{ section.settings.announcement_3 }}
            {% else %}
              EXCLUSIVE: 20% OFF YOUR FIRST ORDER - USE CODE: WELCOME20
            {% endif %}
          </p>
        </div>
        <div class="announcement-slide">
          <p class="text-sm font-medium">
            {% if section.settings.announcement_4 != blank %}
              {{ section.settings.announcement_4 }}
            {% else %}
              NEW SEASON, NEW STYLE - DISCOVER OUR LATEST TRENDS
            {% endif %}
          </p>
        </div>
        <div class="announcement-slide">
          <p class="text-sm font-medium">
            {% if section.settings.announcement_5 != blank %}
              {{ section.settings.announcement_5 }}
            {% else %}
              EASY RETURNS - 30 DAY MONEY BACK GUARANTEE
            {% endif %}
          </p>
        </div>
      </div>
    </div>
    
    <!-- Navigation Dots -->
    <div class="announcement-dots">
      <button class="dot active" onclick="goToSlide(0)"></button>
      <button class="dot" onclick="goToSlide(1)"></button>
      <button class="dot" onclick="goToSlide(2)"></button>
      <button class="dot" onclick="goToSlide(3)"></button>
      <button class="dot" onclick="goToSlide(4)"></button>
    </div>
  </div>

  <!-- Main Header -->
  <div class="container mx-auto px-6 md:px-12 lg:px-16">
    <div class="flex items-center justify-between h-20 lg:h-24">
      
      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-toggle"
        class="lg:hidden p-2 hover:bg-gray-100 rounded-md transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="menu-icon w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg class="close-icon hidden w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <!-- Logo -->
      <div class="flex-1 lg:flex-none text-center lg:text-left">
        <a href="/" class="inline-block">
          {% if section.settings.logo != blank %}
            <img 
              src="{{ section.settings.logo | img_url: '200x' }}" 
              alt="{{ shop.name }}"
              class="h-16 lg:h-20 w-auto object-contain"
              loading="lazy"
            >
          {% else %}
            <img 
              src="https://customer-assets.emergentagent.com/job_boutique-launch/artifacts/u4okpnuu_LOGO%20SR%20%282%29%281%29.png"
              alt="{{ shop.name }}"
              class="h-16 lg:h-20 w-auto object-contain"
              loading="lazy"
            >
          {% endif %}
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center space-x-8 flex-1 justify-center">
        {% for link in linklists[section.settings.menu].links %}
          <a 
            href="{{ link.url }}" 
            class="text-sm font-medium text-gray-700 hover:text-brand-purple transition-colors"
          >
            {{ link.title }}
          </a>
        {% endfor %}
      </nav>

      <!-- Icons -->
      <div class="flex items-center space-x-4">
        <!-- Currency Selector -->
        <div class="relative currency-selector">
          {% if shop.enabled_currencies.size > 1 %}
            {% form 'currency', class: 'currency-form' %}
              <label for="currency-selector" class="sr-only">Select Currency</label>
              <select 
                name="currency" 
                id="currency-selector"
                class="h-10 px-3 pr-8 bg-white border border-gray-200 rounded-md text-sm font-medium text-gray-700 hover:border-brand-purple focus:border-brand-purple focus:ring-2 focus:ring-brand-purple/20 transition-colors cursor-pointer appearance-none"
                onchange="this.form.submit();"
              >
                {% for currency in shop.enabled_currencies %}
                  <option 
                    value="{{ currency.iso_code }}" 
                    {% if currency.iso_code == cart.currency.iso_code %}selected="selected"{% endif %}
                  >
                    {{ currency.iso_code }} {{ currency.symbol }}
                  </option>
                {% endfor %}
              </select>
              <div class="absolute right-2 top-1/2 transform -translate-y-1/2 pointer-events-none">
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>
            {% endform %}
          {% else %}
            <!-- Single currency display -->
            <div class="h-10 px-3 bg-gray-50 border border-gray-200 rounded-md text-sm font-medium text-gray-700 flex items-center">
              {{ cart.currency.iso_code }} {{ cart.currency.symbol }}
            </div>
          {% endif %}
        </div>

        <!-- Search -->
        <a href="/search" class="p-2 hover:bg-gray-100 rounded-md transition-colors" aria-label="Search">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </a>
        
        <!-- Cart -->
        <button onclick="openCartDrawer()" class="p-2 hover:bg-gray-100 rounded-md transition-colors relative" aria-label="Shopping bag">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          <span class="absolute -top-1 -right-1 bg-brand-gold text-white text-xs rounded-full h-5 w-5 flex items-center justify-center" id="cart-count">
            {{ cart.item_count }}
          </span>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <nav id="mobile-menu" class="hidden lg:hidden py-4 border-t border-gray-200">
      <div class="flex flex-col space-y-4">
        {% for link in linklists[section.settings.menu].links %}
          <a
            href="{{ link.url }}"
            class="text-sm font-medium text-gray-700 hover:text-brand-purple transition-colors"
          >
            {{ link.title }}
          </a>
        {% endfor %}
      </div>
    </nav>
  </div>
</header>

<!-- Announcement Bar Slider Styles & Script -->
<style>
.announcement-bar {
  position: relative;
  overflow: hidden;
  padding: 0.5rem 1rem;
}

.announcement-slider {
  position: relative;
  height: 2rem;
}

.announcement-track {
  position: relative;
  height: 100%;
}

.announcement-slide {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: translateX(100%);
  transition: all 0.5s ease;
}

.announcement-slide.active {
  opacity: 1;
  transform: translateX(0);
}

.announcement-slide.prev {
  transform: translateX(-100%);
  opacity: 0;
}

.announcement-dots {
  position: absolute;
  bottom: 0.25rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 0.5rem;
  z-index: 10;
}

.announcement-dots .dot {
  width: 0.5rem;
  height: 0.5rem;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  border: none;
  cursor: pointer;
  transition: all 0.3s;
}

.announcement-dots .dot.active {
  background: white;
  width: 1.5rem;
  border-radius: 0.25rem;
}

.announcement-dots .dot:hover {
  background: rgba(255, 255, 255, 0.7);
}
</style>

<script>
let currentSlide = 0;
const slides = document.querySelectorAll('.announcement-slide');
const dots = document.querySelectorAll('.announcement-dots .dot');
const totalSlides = slides.length;
let slideInterval;

function showSlide(n) {
  // Remove active class from all slides and dots
  slides.forEach(slide => {
    slide.classList.remove('active', 'prev');
  });
  dots.forEach(dot => {
    dot.classList.remove('active');
  });
  
  // Set current slide
  currentSlide = (n + totalSlides) % totalSlides;
  
  // Add active class to current slide and dot
  slides[currentSlide].classList.add('active');
  dots[currentSlide].classList.add('active');
}

function nextSlide() {
  showSlide(currentSlide + 1);
}

function goToSlide(n) {
  clearInterval(slideInterval);
  showSlide(n);
  startSlideShow();
}

function startSlideShow() {
  slideInterval = setInterval(nextSlide, 4000); // Change slide every 4 seconds
}

// Initialize
showSlide(0);
startSlideShow();

// Pause on hover
document.querySelector('.announcement-bar').addEventListener('mouseenter', () => {
  clearInterval(slideInterval);
});

document.querySelector('.announcement-bar').addEventListener('mouseleave', () => {
  startSlideShow();
});
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Announcement Bar Slider"
    },
    {
      "type": "text",
      "id": "announcement_1",
      "label": "Announcement 1",
      "default": "THE SUMMER COLLECTION HAS ARRIVED - SHOP NEW ARRIVALS NOW"
    },
    {
      "type": "text",
      "id": "announcement_2",
      "label": "Announcement 2",
      "default": "FREE SHIPPING ON ORDERS OVER $100 - LIMITED TIME OFFER"
    },
    {
      "type": "text",
      "id": "announcement_3",
      "label": "Announcement 3",
      "default": "EXCLUSIVE: 20% OFF YOUR FIRST ORDER - USE CODE: WELCOME20"
    },
    {
      "type": "text",
      "id": "announcement_4",
      "label": "Announcement 4",
      "default": "NEW SEASON, NEW STYLE - DISCOVER OUR LATEST TRENDS"
    },
    {
      "type": "text",
      "id": "announcement_5",
      "label": "Announcement 5",
      "default": "EASY RETURNS - 30 DAY MONEY BACK GUARANTEE"
    }
  ]
}
{% endschema %}
