{% comment %}
  Featured Collections Section - Split Screen Layout
  Alternating image and text sections with zigzag pattern
{% endcomment %}

<section id="collections" class="py-20 bg-white">
  <div class="container mx-auto px-6 md:px-12 lg:px-16">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-serif font-bold text-brand-purple mb-4">
        {{ section.settings.section_title }}
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto text-lg">
        {{ section.settings.section_description }}
      </p>
    </div>

    <!-- Collections -->
    {% for block in section.blocks %}
      {% assign collection = collections[block.settings.collection] %}
      {% if collection != blank %}
        {% assign is_even = forloop.index | modulo: 3 %}
        
        {% if is_even == 1 or is_even == 2 %}
          <!-- Image Section -->
          <div class="mb-16 lg:mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 items-center {% if is_even == 2 %}lg:flex-row-reverse{% endif %}">
              <!-- Image -->
              <div class="{% if is_even == 2 %}lg:order-2{% else %}lg:order-1{% endif %} relative group overflow-hidden">
                <a href="{{ collection.url }}" class="block aspect-[4/5] relative">
                  {% if collection.image %}
                    <img
                      src="{{ collection.image | img_url: '1200x' }}"
                      alt="{{ collection.title }}"
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                      loading="lazy"
                    >
                  {% elsif collection.products.first.featured_image %}
                    <img
                      src="{{ collection.products.first.featured_image | img_url: '1200x' }}"
                      alt="{{ collection.title }}"
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                      loading="lazy"
                    >
                  {% else %}
                    <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                      <span class="text-gray-400">No image</span>
                    </div>
                  {% endif %}
                  
                  <!-- Overlay -->
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  
                  <!-- Badge -->
                  <div class="absolute top-8 left-8 bg-brand-gold text-white px-4 py-2 text-sm font-bold uppercase tracking-wider">
                    {{ collection.products_count }} Items
                  </div>
                </a>
              </div>

              <!-- Text Content -->
              <div class="{% if is_even == 2 %}lg:order-1 lg:pr-16{% else %}lg:order-2 lg:pl-16{% endif %} py-12 lg:py-0">
                <div class="max-w-lg {% if is_even == 2 %}lg:ml-auto{% endif %}">
                  <span class="text-brand-gold font-medium text-sm uppercase tracking-wider mb-3 block">
                    Collection {{ forloop.index }}
                  </span>
                  
                  <h3 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-6">
                    <a href="{{ collection.url }}" class="hover:text-brand-purple transition-colors">
                      {{ collection.title }}
                    </a>
                  </h3>
                  
                  <p class="text-gray-600 leading-relaxed mb-8 text-lg">
                    {% if block.settings.custom_description != blank %}
                      {{ block.settings.custom_description }}
                    {% elsif collection.description != blank %}
                      {{ collection.description | strip_html | truncate: 200 }}
                    {% else %}
                      Discover our curated selection of premium pieces, each designed with meticulous attention to detail and crafted from the finest materials.
                    {% endif %}
                  </p>
                  
                  <a 
                    href="{{ collection.url }}"
                    class="inline-flex items-center bg-brand-purple hover:bg-brand-gold text-white px-8 py-4 rounded-md font-semibold transition-all duration-300 hover:shadow-lg group"
                  >
                    Explore Collection
                    <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        {% else %}
          <!-- Text-Only Section (Every 3rd item) -->
          <div class="mb-16 lg:mb-24 py-16 bg-gray-50 rounded-2xl">
            <div class="max-w-3xl mx-auto text-center px-6 lg:px-12">
              <span class="text-brand-gold font-medium text-sm uppercase tracking-wider mb-4 block">
                Our Philosophy
              </span>
              
              <h3 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-6">
                Timeless Elegance Meets Modern Sophistication
              </h3>
              
              <p class="text-gray-600 leading-relaxed text-lg mb-8">
                At Shauvre, we believe in creating beautiful luxury pieces that transcend seasons. 
                Every collection tells a story of craftsmanship, quality, and timeless style. 
                From hand-selected fabrics to meticulous tailoring, each piece is designed to be treasured for years to come.
              </p>
              
              <div class="grid grid-cols-3 gap-8 pt-8 border-t border-gray-200">
                <div>
                  <p class="text-3xl font-bold text-brand-purple mb-2">{{ collection.products_count }}+</p>
                  <p class="text-sm text-gray-600">Curated Pieces</p>
                </div>
                <div>
                  <p class="text-3xl font-bold text-brand-purple mb-2">100%</p>
                  <p class="text-sm text-gray-600">Premium Quality</p>
                </div>
                <div>
                  <p class="text-3xl font-bold text-brand-purple mb-2">30+</p>
                  <p class="text-sm text-gray-600">Years Craftsmanship</p>
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Featured Collections"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Section Description",
      "default": "Explore our curated collections of timeless pieces, each designed with meticulous attention to detail and crafted from the finest materials."
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom Description (optional)",
          "info": "Leave blank to use collection description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
