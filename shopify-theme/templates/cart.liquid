{% comment %}
  Cart Template
{% endcomment %}

<div class="cart-page py-12 bg-white min-h-screen">
  <div class="container mx-auto px-6 md:px-12 lg:px-16">
    
    <h1 class="text-3xl md:text-4xl font-serif font-bold text-brand-purple mb-8">
      Shopping Cart
    </h1>

    {% if cart.item_count > 0 %}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        
        <div class="lg:col-span-2">
          {% for item in cart.items %}
            <div class="flex gap-6 border-b pb-6 mb-6">
              <img 
                src="{{ item.image | img_url: '200x' }}" 
                alt="{{ item.title }}"
                class="w-24 h-32 object-cover rounded-md"
              >
              <div class="flex-1">
                <h3 class="text-lg font-semibold">{{ item.product.title }}</h3>
                <p class="text-brand-purple font-bold mt-2">{{ item.price | money }}</p>
                <p class="text-sm text-gray-600 mt-1">Qty: {{ item.quantity }}</p>
              </div>
              <div class="text-right">
                <p class="text-lg font-bold">{{ item.line_price | money }}</p>
              </div>
            </div>
          {% endfor %}
        </div>

        <div>
          <div class="bg-gray-50 rounded-lg p-6 sticky top-24">
            <h2 class="text-xl font-bold mb-6">Order Summary</h2>
            <div class="space-y-4 mb-6">
              <div class="flex justify-between">
                <span>Subtotal</span>
                <span>{{ cart.total_price | money }}</span>
              </div>
              <div class="border-t pt-4">
                <div class="flex justify-between text-lg font-bold">
                  <span>Total</span>
                  <span>{{ cart.total_price | money }}</span>
                </div>
              </div>
            </div>
            <a 
              href="/checkout"
              class="block w-full bg-brand-purple hover:bg-brand-gold text-white text-center font-semibold py-4 rounded-md transition-all"
            >
              Checkout
            </a>
          </div>
        </div>
      </div>
    {% else %}
      <div class="text-center py-20">
        <h2 class="text-2xl font-bold mb-4">Your cart is empty</h2>
        <a href="/collections" class="text-brand-purple hover:text-brand-gold">Start Shopping</a>
      </div>
    {% endif %}
  </div>
</div>
