{% comment %}
  Product Template - Individual product page
{% endcomment %}

<div class="product-page py-12 bg-white">
  <div class="container mx-auto px-6 md:px-12 lg:px-16">
    
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-8">
      <a href="/" class="hover:text-brand-purple transition-colors">Home</a>
      <span class="mx-2">/</span>
      {% if product.collections.size > 0 %}
        <a href="{{ product.collections.first.url }}" class="hover:text-brand-purple transition-colors">
          {{ product.collections.first.title }}
        </a>
        <span class="mx-2">/</span>
      {% endif %}
      <span class="text-gray-900">{{ product.title }}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      
      <!-- Product Images -->
      <div class="space-y-4">
        <!-- Main Image -->
        <div class="rounded-lg overflow-hidden aspect-[3/4] bg-gray-100">
          <img 
            id="main-product-image"
            src="{{ product.featured_image | img_url: '1000x' }}" 
            alt="{{ product.title }}"
            class="w-full h-full object-cover"
          >
        </div>
        
        <!-- Thumbnail Gallery -->
        {% if product.images.size > 1 %}
          <div class="grid grid-cols-4 gap-4">
            {% for image in product.images %}
              <button 
                onclick="document.getElementById('main-product-image').src='{{ image | img_url: '1000x' }}'"
                class="rounded-md overflow-hidden border-2 border-transparent hover:border-brand-purple transition-colors aspect-square"
              >
                <img 
                  src="{{ image | img_url: '200x' }}" 
                  alt="{{ product.title }}"
                  class="w-full h-full object-cover"
                >
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Product Info -->
      <div class="space-y-6">
        <div>
          <h1 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-4">
            {{ product.title }}
          </h1>
          
          <div class="flex items-baseline gap-3">
            {% if product.compare_at_price > product.price %}
              <span class="text-3xl font-bold text-red-600">
                {{ product.price | money }}
              </span>
              <span class="text-xl text-gray-400 line-through">
                {{ product.compare_at_price | money }}
              </span>
            {% else %}
              <span class="text-3xl font-bold text-gray-900">
                {{ product.price | money }}
              </span>
            {% endif %}
          </div>
        </div>

        <!-- Description -->
        {% if product.description != blank %}
          <div class="text-gray-600 leading-relaxed border-t border-b border-gray-200 py-6">
            {{ product.description }}
          </div>
        {% endif %}

        <!-- Product Form -->
        {% form 'product', product %}
          <div class="space-y-6">
            <!-- Variants -->
            {% unless product.has_only_default_variant %}
              <div>
                <label class="block text-sm font-semibold text-gray-900 mb-3">Options</label>
                <select name="id" class="w-full px-4 py-3 border border-gray-200 rounded-md">
                  {% for variant in product.variants %}
                    <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                      {{ variant.title }} - {{ variant.price | money }}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% endunless %}

            <!-- Quantity -->
            <div>
              <label class="block text-sm font-semibold text-gray-900 mb-3">Quantity</label>
              <input 
                type="number" 
                name="quantity" 
                value="1" 
                min="1"
                class="w-24 px-4 py-3 border border-gray-200 rounded-md"
              >
            </div>

            <!-- Add to Cart Button -->
            <button 
              type="submit"
              class="w-full bg-brand-purple hover:bg-brand-gold text-white font-semibold py-4 px-8 rounded-md transition-all duration-300 hover:shadow-lg"
              {% unless product.available %}disabled{% endunless %}
            >
              {% if product.available %}
                Add to Cart
              {% else %}
                Sold Out
              {% endif %}
            </button>
          </div>
        {% endform %}

        <!-- Product Features -->
        <div class="grid grid-cols-2 gap-4 pt-6 border-t border-gray-200">
          <div class="flex items-center gap-3">
            <span class="text-2xl">🚚</span>
            <div>
              <p class="text-sm font-semibold">Free Shipping</p>
              <p class="text-xs text-gray-500">On orders over $100</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-2xl">↩️</span>
            <div>
              <p class="text-sm font-semibold">Easy Returns</p>
              <p class="text-xs text-gray-500">30-day policy</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
