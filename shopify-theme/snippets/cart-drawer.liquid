{% comment %}
  Cart Drawer - Slides from right
{% endcomment %}

<div id="cart-drawer" class="cart-drawer">
  <div class="cart-drawer-overlay" onclick="closeCartDrawer()"></div>
  
  <div class="cart-drawer-content">
    <!-- Header -->
    <div class="cart-drawer-header">
      <h2 class="text-2xl font-serif font-bold text-gray-900">Shopping Cart</h2>
      <button onclick="closeCartDrawer()" class="cart-drawer-close" aria-label="Close cart">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Cart Items -->
    <div class="cart-drawer-items">
      <div id="cart-items-container">
        {% if cart.item_count > 0 %}
          {% for item in cart.items %}
            <div class="cart-item" data-line="{{ forloop.index }}">
              <a href="{{ item.url }}" class="cart-item-image">
                {% if item.image %}
                  <img src="{{ item.image | img_url: '150x' }}" alt="{{ item.title }}">
                {% else %}
                  <div class="no-image">No image</div>
                {% endif %}
              </a>
              
              <div class="cart-item-details">
                <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                {% unless item.variant.title contains 'Default' %}
                  <p class="cart-item-variant">{{ item.variant.title }}</p>
                {% endunless %}
                
                <div class="cart-item-price">
                  <span class="price">{{ item.price | money }}</span>
                  {% if item.original_price > item.price %}
                    <span class="original-price">{{ item.original_price | money }}</span>
                  {% endif %}
                </div>
                
                <!-- Quantity Controls -->
                <div class="cart-item-quantity">
                  <button 
                    onclick="updateCartItem({{ forloop.index }}, {{ item.quantity | minus: 1 }})"
                    class="qty-btn"
                    {% if item.quantity <= 1 %}disabled{% endif %}
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                    </svg>
                  </button>
                  
                  <span class="qty-value">{{ item.quantity }}</span>
                  
                  <button 
                    onclick="updateCartItem({{ forloop.index }}, {{ item.quantity | plus: 1 }})"
                    class="qty-btn"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                  </button>
                </div>
              </div>
              
              <div class="cart-item-actions">
                <p class="cart-item-total">{{ item.line_price | money }}</p>
                <button 
                  onclick="removeCartItem({{ forloop.index }})"
                  class="cart-item-remove"
                  aria-label="Remove item"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                </button>
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="cart-empty">
            <svg class="cart-empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
            <p class="cart-empty-text">Your cart is empty</p>
            <button onclick="closeCartDrawer()" class="cart-empty-btn">Continue Shopping</button>
          </div>
        {% endif %}
      </div>
    </div>

    <!-- Footer -->
    {% if cart.item_count > 0 %}
      <div class="cart-drawer-footer">
        <!-- Subtotal -->
        <div class="cart-subtotal">
          <span>Subtotal</span>
          <span class="cart-subtotal-amount" id="cart-total">{{ cart.total_price | money }}</span>
        </div>
        
        <p class="cart-note">Shipping & taxes calculated at checkout</p>
        
        <!-- Buttons -->
        <div class="cart-actions">
          <a href="/cart" class="btn-secondary" onclick="closeCartDrawer()">View Cart</a>
          <a href="/checkout" class="btn-primary">
            Checkout
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
        
        <!-- Trust Badges -->
        <div class="cart-trust-badges">
          <div class="trust-badge">
            <span>🔒</span>
            <span>Secure Checkout</span>
          </div>
          <div class="trust-badge">
            <span>🚚</span>
            <span>Free Shipping $100+</span>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

<style>
/* Cart Drawer Styles */
.cart-drawer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 9999;
  pointer-events: none;
}

.cart-drawer.active {
  pointer-events: auto;
}

.cart-drawer-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.cart-drawer.active .cart-drawer-overlay {
  opacity: 1;
}

.cart-drawer-content {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  max-width: 480px;
  background: white;
  transform: translateX(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
  box-shadow: -4px 0 12px rgba(0, 0, 0, 0.1);
}

.cart-drawer.active .cart-drawer-content {
  transform: translateX(0);
}

.cart-drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem;
  border-bottom: 1px solid #e5e7eb;
}

.cart-drawer-close {
  padding: 0.5rem;
  border-radius: 0.375rem;
  transition: background-color 0.2s;
}

.cart-drawer-close:hover {
  background-color: #f3f4f6;
}

.cart-drawer-items {
  flex: 1;
  overflow-y: auto;
  padding: 1.5rem;
}

.cart-item {
  display: flex;
  gap: 1rem;
  padding-bottom: 1.5rem;
  margin-bottom: 1.5rem;
  border-bottom: 1px solid #e5e7eb;
}

.cart-item-image {
  flex-shrink: 0;
  width: 100px;
  height: 120px;
  border-radius: 0.5rem;
  overflow: hidden;
}

.cart-item-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.no-image {
  width: 100%;
  height: 100%;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  color: #9ca3af;
}

.cart-item-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.cart-item-title {
  font-weight: 600;
  color: #111827;
  font-size: 0.95rem;
  line-height: 1.3;
}

.cart-item-title:hover {
  color: #4C1C5B;
}

.cart-item-variant {
  font-size: 0.875rem;
  color: #6b7280;
}

.cart-item-price {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.cart-item-price .price {
  font-weight: 700;
  color: #4C1C5B;
  font-size: 1rem;
}

.cart-item-price .original-price {
  font-size: 0.875rem;
  color: #9ca3af;
  text-decoration: line-through;
}

.cart-item-quantity {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: 0.5rem;
}

.qty-btn {
  width: 2rem;
  height: 2rem;
  border: 1px solid #d1d5db;
  border-radius: 0.375rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.qty-btn:hover:not(:disabled) {
  border-color: #4C1C5B;
  background: #4C1C5B;
  color: white;
}

.qty-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.qty-value {
  font-weight: 600;
  min-width: 2rem;
  text-align: center;
}

.cart-item-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 1rem;
}

.cart-item-total {
  font-weight: 700;
  font-size: 1.125rem;
  color: #111827;
}

.cart-item-remove {
  padding: 0.5rem;
  color: #ef4444;
  border-radius: 0.375rem;
  transition: background-color 0.2s;
}

.cart-item-remove:hover {
  background: #fee2e2;
}

.cart-empty {
  text-align: center;
  padding: 3rem 1rem;
}

.cart-empty-icon {
  width: 4rem;
  height: 4rem;
  margin: 0 auto 1.5rem;
  color: #d1d5db;
}

.cart-empty-text {
  font-size: 1.125rem;
  color: #6b7280;
  margin-bottom: 1.5rem;
}

.cart-empty-btn {
  background: #4C1C5B;
  color: white;
  padding: 0.75rem 2rem;
  border-radius: 0.5rem;
  font-weight: 600;
  transition: background-color 0.2s;
}

.cart-empty-btn:hover {
  background: #E1921D;
}

.cart-drawer-footer {
  border-top: 1px solid #e5e7eb;
  padding: 1.5rem;
  background: #f9fafb;
}

.cart-subtotal {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.cart-subtotal-amount {
  color: #4C1C5B;
}

.cart-note {
  font-size: 0.875rem;
  color: #6b7280;
  margin-bottom: 1.5rem;
}

.cart-actions {
  display: flex;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  padding: 1rem;
  border-radius: 0.5rem;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #4C1C5B;
  color: white;
}

.btn-primary:hover {
  background: #E1921D;
  box-shadow: 0 4px 12px rgba(76, 28, 91, 0.3);
}

.btn-secondary {
  background: white;
  color: #4C1C5B;
  border: 2px solid #4C1C5B;
}

.btn-secondary:hover {
  background: #4C1C5B;
  color: white;
}

.cart-trust-badges {
  display: flex;
  gap: 1rem;
  padding-top: 1rem;
  border-top: 1px solid #e5e7eb;
}

.trust-badge {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  color: #6b7280;
}

/* Mobile Adjustments */
@media (max-width: 640px) {
  .cart-drawer-content {
    max-width: 100%;
  }
  
  .cart-actions {
    flex-direction: column;
  }
}
</style>

<script>
// Cart Drawer Functions
function openCartDrawer() {
  document.getElementById('cart-drawer').classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeCartDrawer() {
  document.getElementById('cart-drawer').classList.remove('active');
  document.body.style.overflow = '';
}

function updateCartItem(line, quantity) {
  fetch('/cart/change.js', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      line: line,
      quantity: quantity
    })
  })
  .then(response => response.json())
  .then(data => {
    location.reload(); // Reload to update cart
  })
  .catch(error => {
    console.error('Error:', error);
  });
}

function removeCartItem(line) {
  if (confirm('Remove this item from cart?')) {
    updateCartItem(line, 0);
  }
}

// Close drawer on escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    closeCartDrawer();
  }
});
</script>
